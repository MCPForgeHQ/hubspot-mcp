# HubSpot MCP — environment variables
# Copy this file to .env and fill in your values

# MCPForge endpoint for this MCP server
# Get your endpoint from https://mcpforge.tech/dashboard
MCP_ENDPOINT=https://www.mcpforge.tech/api/servers/hubspot-mcp-demo

# MCPForge API key (required for private servers)
# Generate one at https://mcpforge.tech/dashboard -> Settings -> API Keys
MCPFORGE_API_KEY=

# HubSpot private app access token (required for live operations)
# Create a private app at https://app.hubspot.com/private-apps
HUBSPOT_ACCESS_TOKEN=pat-...
